# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
# /out/  -- 注释掉：out 目录已纳入提交用于静态托管，详见 netlify.toml

# production
/build
# out 目录已纳入提交，用于静态托管

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local snapshots from Claude
/.snapshots/

# typescript
*.tsbuildinfo
next-env.d.ts
